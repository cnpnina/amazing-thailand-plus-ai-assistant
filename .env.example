# =========================
# Required API keys
# =========================
EXA_API_KEY=your_exa_api_key_here

# Use either GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# =========================
# Gemini model settings
# =========================
# Required for planner
GEMINI_MODEL=gemini-2.5-flash

# Optional: search fallback model in discovery
# If empty, code falls back to GEMINI_MODEL
# Google Gemini API (ChatGoogleGenerativeAI)
GOOGLE_API_KEY=
GEMINI_SEARCH_MODEL=gemini-2.5-flash

# =========================
# Embedding settings
# =========================
# Optional override (default in code is jinaai/jina-embeddings-v5-text-small)
EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-small

# Optional but recommended for Hugging Face download limits/speed
HF_TOKEN=

# =========================
# Optional log tuning
# =========================
PREFECT_LOGGING_LEVEL=WARNING
PREFECT_SERVER_LOGGING_LEVEL=WARNING
